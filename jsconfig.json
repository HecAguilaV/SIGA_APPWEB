{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jasmine", "node"]
  },
  "include": ["src/**/*", "karma.conf.js"],
  "exclude": ["node_modules", "dist"]
}
